# See how many buckets total
aws s3api list-buckets --query "Buckets[*].Name" --output text | tr '\t' '\n' | wc -l

# List them all so we can see what we're dealing with
aws s3api list-buckets --query "Buckets[*].Name" --output text | tr '\t' '\n'


for bucket in $(aws s3api list-buckets --query "Buckets[*].Name" --output text); do
    echo -n "Checking: $bucket ... "
    timeout 10 aws s3api get-bucket-encryption --bucket "$bucket" > /dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "✓ encrypted"
    elif [ $? -eq 124 ]; then
        echo "⚠ TIMED OUT"
    else
        echo "✗ no encryption / access denied"
    fi
done
